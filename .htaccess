RewriteEngine On

# Parse .html files as PHP so shared include files can be used without renaming pages.
AddType application/x-httpd-php .html

# Canonicalize only public /heritagehaat/*.html URLs to extensionless URLs.
# Using REQUEST_URI avoids accidental matches against server filesystem paths.
RewriteCond %{REQUEST_URI} ^/heritagehaat/(.+)\.html$ [NC]
RewriteRule ^ /heritagehaat/%1 [R=301,L,NE]

# Serve extensionless URLs from matching .html files.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

DirectoryIndex index.html

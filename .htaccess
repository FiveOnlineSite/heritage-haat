RewriteEngine On

# Redirect /heritagehaat/page.html to /heritagehaat/page
RewriteCond %{THE_REQUEST} \s/+heritagehaat/([^\s?]+?)\.html[\s?] [NC]
RewriteRule ^heritagehaat/(.+)\.html$ /heritagehaat/$1 [R=301,L,NE]

# Serve extensionless URLs from matching .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ /$1.html [L]

DirectoryIndex index.html

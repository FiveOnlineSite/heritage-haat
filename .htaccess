RewriteEngine On

# Parse .html files as PHP so shared include files can be used without renaming pages.
AddType application/x-httpd-php .html

# Keep rewrite target rooted in this project directory to avoid duplicated path segments.
RewriteBase /heritagehaat/

# Redirect explicit .html URLs to extensionless canonical URLs.
RewriteCond %{THE_REQUEST} \s/+heritagehaat/([^\s?]+?)\.html(?:[\s?]|$) [NC]
RewriteRule ^ %1 [R=301,L,NE]

# Serve extensionless URLs from matching .html files.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

DirectoryIndex index.html
